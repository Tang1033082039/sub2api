# 确保所有 SQL 迁移文件使用 LF 换行符
backend/migrations/*.sql text eol=lf

# Go 源代码文件
*.go text eol=lf

# 前端 源代码文件
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.vue text eol=lf

# Shell 脚本
*.sh text eol=lf

# YAML/YML 配置文件
*.yaml text eol=lf
*.yml text eol=lf

# Dockerfile
Dockerfile text eol=lf

# 本仓库的版本号由 fork 维护，合并上游时始终保留本地 VERSION
backend/cmd/server/VERSION merge=ours
